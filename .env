# =========================================
# Core MCP Server Configuration
# =========================================
MCP_SERVER_NAME=my-mcp-server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# =========================================
# Authentication / Security
# =========================================
MCP_API_KEY=your_api_key_here
MCP_AUTH_ENABLED=true

# Optional: JWT / Token settings
MCP_JWT_SECRET=your_jwt_secret_here
MCP_TOKEN_EXPIRY=3600

# =========================================
# Azure / Cloud Integration
# =========================================
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=your_resource_group
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# =========================================
# OpenAI / Model Configuration
# =========================================
OPENAI_API_KEY=your_openai_key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# If using Azure OpenAI
AZURE_OPENAI_ENDPOINT=your_endpoint_url
AZURE_OPENAI_DEPLOYMENT=your_model_deployment_name

# =========================================
# Tool / Service Endpoints (MCP Tools)
# =========================================
# Example: External API exposed as MCP tool
WEATHER_API_URL=https://api.weatherapi.com
WEATHER_API_KEY=your_weather_key

# Example: Internal service endpoint
INVENTORY_API_URL=http://localhost:5000/api

# =========================================
# Database (Optional)
# =========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mcp_db
DB_USER=postgres
DB_PASSWORD=your_password

# =========================================
# Logging / Debugging
# =========================================
LOG_LEVEL=debug
ENABLE_VERBOSE_LOGGING=true

# =========================================
# Feature Flags
# =========================================
ENABLE_TOOL_REGISTRATION=true
ENABLE_AGENT_ORCHESTRATION=true
ENABLE_VECTOR_STORE=true